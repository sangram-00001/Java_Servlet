<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.giet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>


    <!-- Student Servlet -->
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.giet.StudentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/student</url-pattern>
    </servlet-mapping>


    <!-- Multiply Servlet -->
    <servlet>
        <servlet-name>MultiplyServlet</servlet-name>
        <servlet-class>com.giet.MultiplyServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>MultiplyServlet</servlet-name>
        <url-pattern>/multiply</url-pattern>
    </servlet-mapping>


    <!-- Employee Servlet -->
    <servlet>
        <servlet-name>EmployeePost</servlet-name>
        <servlet-class>com.giet.EmployeePost</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>EmployeePost</servlet-name>
        <url-pattern>/employee</url-pattern>
    </servlet-mapping>


    <!-- Rectangle Servlet -->
    <servlet>
        <servlet-name>RectangleServlet</servlet-name>
        <servlet-class>com.giet.RectangleServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RectangleServlet</servlet-name>
        <url-pattern>/rectangle</url-pattern>
    </servlet-mapping>


    <!-- Common Servlet -->
    <servlet>
        <servlet-name>CommonServlet</servlet-name>
        <servlet-class>com.giet.CommonServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CommonServlet</servlet-name>
        <url-pattern>/common</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>aaa</servlet-name>
        <servlet-class>pack.aaa</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>aaa</servlet-name>
        <url-pattern>/aaa</url-pattern>
    </servlet-mapping>

    <!-- bbb Servlet -->
    <servlet>
        <servlet-name>bbb</servlet-name>
        <servlet-class>pack.bbb</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>bbb</servlet-name>
        <url-pattern>/bbb</url-pattern>
    </servlet-mapping>

<servlet>
<servlet-name>ccc</servlet-name>
<servlet-class>com.giet.ccc</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>ccc</servlet-name>
<url-pattern>/ccc</url-pattern>
</servlet-mapping>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>


</web-app>


